# Large File Bridge CLI — task runner (pm/cli.mdx §1.3). `just build` / `just run …` work here,
# and the ROOT justfile's build/run also build this CLI so it is never stale.
set shell := ["bash", "-uc"]

code := justfile_directory() + "/code"

default:
    @just --list

# Install deps + compile the CLI to code/dist/.
build:
    cd {{code}} && pnpm install && pnpm build

# Typecheck only (no emit).
typecheck:
    cd {{code}} && pnpm install && pnpm typecheck

# Build, then run the CLI with the given arguments (e.g. `just run files --all --compress`).
run *args: build
    {{justfile_directory()}}/lfb {{args}}
