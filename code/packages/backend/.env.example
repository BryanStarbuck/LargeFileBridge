# LargeFileBridge backend — copy to .env (just setup does this). Secrets prefer
# ~/.credentials/large_files_bridge.json; env wins over the file.
NODE_ENV=development

# Ports (also settable in ~/T/_large_files_bridge/config.yaml → server)
PORT=8787

# CORS — the Vite dev origin (web app defaults to :2222). In local mode the API accepts this list
# PLUS the frontend port band (2222..+16) so a collision-moved web port still reaches it — but NOT an
# arbitrary localhost origin (security audit finding 6). Server mode fails closed to this list only.
CORS_ORIGINS=http://localhost:2222

# OpenAuthFederated / Google Workspace OIDC (leave blank to boot without sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/v1/oauth_callback

# Comma-separated Google Workspace domains permitted to sign in.
AUTH_ALLOWED_DOMAINS=act3ai.com

# Cookie hardening. COOKIE_SECURE applies ONLY to local (plain-http) dev, where Secure+HSTS would
# break the http://localhost OAuth callback. Server mode ALWAYS sets Secure cookies regardless of this
# value (security audit finding 5) — so this line can never ship a non-Secure cookie to production.
AUTH_COOKIE_PREFIX=oaf_lfb
COOKIE_SECURE=false

# State + logs (default ~/T/_large_files_bridge)
# LFB_STATE_DIR=
# LFB_LOG_DIR=
# LFB_CREDENTIALS_FILE=

# Localhost dev bypass (security audit finding 1). ONLY active when ALL hold: local mode, the request
# comes from loopback (this machine), this flag is EXPLICITLY "true", security is configured, and no
# Google creds are set. It then treats the first allow-listed email as a signed-in admin so the UI is
# usable offline. It is NOT reachable over the network and never applies in server mode. Set to any
# other value (or unset) to disable.
LFB_DEV_AUTH=true
